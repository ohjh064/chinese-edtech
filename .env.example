# Supabase (프로젝트 설정 > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# 서버 전용(절대 클라이언트에 노출 금지) — 정답키 읽기/채점, 키 저장 등 관리 작업용
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# 교사 API 키 암호화용 비밀(16자 이상, 아무 긴 랜덤 문자열). 배포 시 반드시 설정·고정.
#  예: openssl rand -base64 48
APP_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET

# (선택) 운영자 공용 Claude 키 — BYOK(교사별 키)가 우선. 교사 키가 없을 때만 fallback.
#  무료 배포 시에는 비워두세요(교사별 키로 과금되도록).
ANTHROPIC_API_KEY=
